# Google Vertex / Gemini (required)
GOOGLE_VERTEX_API_KEY=
# Optional — default gemini-2.0-flash or team preview id
VERTEX_MODEL=

# Server (optional — default 4000)
SERVER_PORT=4000

# Telegram bot from @BotFather (required for demo)
TELEGRAM_BOT_TOKEN=

# Supermemory — same key / project as doze (required)
SUPERMEMORY_API_KEY=

# Perplexity Sonar for searchProducts (required)
PERPLEXITY_API_KEY=

# Outdoze staging API base URL, no trailing slash (required)
OUTDOZE_API_BASE_URL=https://your-staging-host.example.com
# Optional — only if staging routes require auth
OUTDOZE_API_KEY=

# Poster artifact output directory (optional)
ARTIFACT_DIR=/tmp/doze-test-artifacts

# Vapi outbound calls — omit for stub mode (optional)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Vapi transcript filter via Claude Haiku; regex fallback without this (optional)
ANTHROPIC_API_KEY=
